# =============================================================================
# MALE VITAMIN — ENVIRONMENT VARIABLE TEMPLATE
# =============================================================================
# Copy this file to ".env" and fill in the real values.
#
#   cp .env.example .env
#
# NEVER commit the real ".env" file. It is git-ignored on purpose.
# See CREDENTIALS_SETUP.md for where to obtain each value.
# =============================================================================


# --- DATABASE -----------------------------------------------------------------
# Prisma connection string. For local dev with SQLite, a file path is fine.
DATABASE_URL="file:./db/custom.db"


# --- CLOUDFLARE (optional — only needed for Worker proxy deployment) ----------
CLOUDFLARE_EMAIL="your-email@example.com"
CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"
CLOUDFLARE_API_KEY="your-cloudflare-api-key"
CLOUDFLARE_WORKER_NAME="your-worker-name"
CLOUDFLARE_WORKERS_DEV_ROUTE="your-worker.your-subdomain.workers.dev"


# --- FLUTTERWAVE PAYMENT ------------------------------------------------------
# Public key is exposed to the browser (NEXT_PUBLIC_*). Secret key is server-only.
# Use TEST keys for development, LIVE keys only in production.
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY="FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxx-X"
FLUTTERWAVE_SECRET_KEY="FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxx-X"


# --- FLUTTERWAVE SUBACCOUNTS (for split payment) ------------------------------
# Create these in the Flutterwave dashboard. Leave blank to disable splitting.
FLUTTERWAVE_OWNER_SUBACCOUNT_ID=""
FLUTTERWAVE_PARTNER_SUBACCOUNT_ID=""


# --- PAYMENT SPLIT CONFIGURATION ----------------------------------------------
SPLIT_OWNER_PERCENTAGE="25"
SPLIT_OWNER_LABEL="Owner"
SPLIT_PARTNER_PERCENTAGE="75"
SPLIT_PARTNER_LABEL="JVL"
SPLIT_PARTNER_2_SUBACCOUNT_ID=""
SPLIT_PARTNER_2_PERCENTAGE="0"
SPLIT_PARTNER_2_LABEL="Partner 2"
SPLIT_PARTNER_3_SUBACCOUNT_ID=""
SPLIT_PARTNER_3_PERCENTAGE="0"
SPLIT_PARTNER_3_LABEL="Partner 3"


# --- PRODUCT CONFIG -----------------------------------------------------------
# Amount is in cents (e.g. 85000 = R 850.00).
NEXT_PUBLIC_BUSINESS_NAME="Male Vitamin"
NEXT_PUBLIC_AMOUNT="85000"
NEXT_PUBLIC_CURRENCY="ZAR"


# --- DELIVERY FEES (in cents) -------------------------------------------------
DELIVERY_FEE_NORMAL="8900"
DELIVERY_FEE_SPEED="11900"
DELIVERY_CURRENCY="ZAR"


# --- OWNER BANK DETAILS (settlement recipient #1) -----------------------------
# Sensitive PII — keep out of version control.
OWNER_BANK="Bank Name"
OWNER_ACCOUNT_NAME="Account Holder Name"
OWNER_ACCOUNT_NUMBER="0000000000"
OWNER_BRANCH="000000"
OWNER_PHONE=""
OWNER_SALE_EMAIL=""


# --- PARTNER BANK DETAILS (settlement recipient #2) ---------------------------
PARTNER_BANK="Bank Name"
PARTNER_ACCOUNT_NAME="Account Holder Name"
PARTNER_ACCOUNT_NUMBER="0000000000"
PARTNER_BRANCH="Branch"


# --- PARTNER CONTACT NUMBERS (WhatsApp order notifications) --------------------
# International format, e.g. +27831234567. Leave blank to skip a recipient.
JVL_PHONE_NICO=""
JVL_PHONE_ANA=""
JVL_PHONE_CHALYN=""
JVL_PHONE_JACQUES=""
JVL_SALE_EMAIL=""


# --- WHATSAPP GATEWAY ---------------------------------------------------------
# Universal WhatsApp Gateway used to send order notifications.
WHATSAPP_GATEWAY_URL="https://your-whatsapp-gateway-endpoint"
WHATSAPP_GATEWAY_KEY="your-whatsapp-gateway-key"
WHATSAPP_PRODUCT_NAME="your-registered-product-name"


# --- SMTP EMAIL ---------------------------------------------------------------
# Used by nodemailer (/api/send-email). For Gmail use an App Password.
SMTP_HOST="smtp.your-provider.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@your-domain.com"


# --- EMAIL API (optional alternative to SMTP) ---------------------------------
EMAIL_API_URL=""
